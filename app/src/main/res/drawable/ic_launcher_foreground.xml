    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Safe zone center: 54,54 — icon drawn within 24dp radius -->

    <!-- Outer eye shape (almond / lens contour) -->
    <path
        android:name="eye_outline"
        android:pathData="M30,54 Q42,36 54,36 Q66,36 78,54 Q66,72 54,72 Q42,72 30,54 Z"
        android:strokeColor="#FF00FF41"
        android:strokeWidth="2.5"
