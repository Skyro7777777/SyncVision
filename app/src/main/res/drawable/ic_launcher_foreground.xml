    <path
        android:name="iris"
        android:pathData="M44,54 A10,10 0 1,1 64,54 A10,10 0 1,1 44,54 Z"
        android:strokeColor="#FF00FF41"
        android:strokeWidth="2"
        android:fillColor="#1A00FF41" />

