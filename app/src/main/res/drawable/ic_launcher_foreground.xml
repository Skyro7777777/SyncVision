<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     Sync Vision — Launcher Icon Foreground
     Minimal geometric eye/camera icon suggesting vision and sync.
     Terminal green (#00FF41) on transparent background.
     Design: stylized eye with lens circle and radiating arcs
     ============================================================ -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
