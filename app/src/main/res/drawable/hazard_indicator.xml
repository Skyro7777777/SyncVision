<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     Sync Vision — Hazard Indicator Drawable
     Animated pulsing circle for threat indication in HUD.
     Color transitions: green (safe) → yellow (low) → orange
     (medium) → red (high) based on hazard level.
     Default state is green (safe). Color is changed
     programmatically via setColorFilter() on the view.
     ============================================================ -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow ring (pulsing animation target) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/sync_green_translucent_20" />
            <size android:width="12dp" android:height="12dp" />
        </shape>
    </item>

    <!-- Inner solid circle (hazard color indicator) -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/sync_green" />
            <size android:width="8dp" android:height="8dp" />
        </shape>
    </item>

</layer-list>
