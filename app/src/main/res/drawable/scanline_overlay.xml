<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     Sync Vision — Scanline Overlay Drawable
     Layer-list drawable creating a CRT scanline effect with
     subtle semi-transparent horizontal green lines at 2-3% opacity
     ============================================================ -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base transparent layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Scanline group 1: every 4px, 1px green line (2% opacity) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="@color/scanline_green"
                android:dashWidth="1dp"
                android:dashGap="3dp" />
        </shape>
    </item>

    <!-- Scanline group 2: offset pattern for denser CRT effect (3% opacity) -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="@color/scanline_green"
                android:dashWidth="1dp"
                android:dashGap="7dp" />
        </shape>
    </item>

    <!-- Subtle horizontal gradient for CRT barrel effect -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#00000000"
                android:centerColor="#0300FF41"
                android:endColor="#00000000" />
        </shape>
    </item>

</layer-list>
